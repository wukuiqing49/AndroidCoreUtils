    <string name="code_log"><![CDATA[CoreUtils.init(
    this,
    CoreUtilsConfig(
        initLog = true,
        debug = BuildConfig.DEBUG,
        logToFile = true,
        showLogStackInfo = true,
        logCaptureCrash = false
    )
)

ALog.d("Demo", "debug")
ALog.e("Demo", "failed", throwable)
ALog.flushSync()
val files = ALog.getLogFiles()]]></string>

